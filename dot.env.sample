# Ẑelkova — Configuration de l'environnement
# ================================================================
# Copier vers .env (production) ou .env.dev (développement)
# ================================================================

# ─── Réseau Duniter V2 (Ğ1) ──────────────────────────────────
CURRENCY=ẐEN

# Hash du bloc genesis Ğ1 (réseau de production Duniter V2)
# Identique à Ginkgo branche zen — NE PAS MODIFIER sauf changement réseau
GENESIS_HASH=0xfeb770bbb0344dabc8366b0d1f889a8e4e6ca09b914006655fe795920deb6d56

# ─── Nœuds RPC Duniter V2 (WebSocket) ────────────────────────
# Plusieurs nœuds séparés par des espaces = auto-sélection + fallback
# Ordre de découverte : duniter_getnode.sh (health check + latence)
# Sources de référence : https://git.duniter.org/nodes/networks/-/raw/main/g1.json
ENDPOINTS=wss://rpc.duniter.org wss://g1.axiom-team.fr/ws/ wss://g1.p2p.legal/ws wss://g1.asycn.io/ws/ wss://g1.coinduf.eu wss://g1.gyroi.de wss://archive-rpc.g1.brussels.ovh wss://g1.rendall.fr/ws wss://g1.pini.fr/ws wss://g1.1000i100.fr

# ─── Indexers Squid (GraphQL — historique + WoT) ──────────────
# Plusieurs indexers = fallback automatique si l'un est indisponible
DUNITER_INDEXER_NODES=https://indexer.duniter.org/v1/graphql https://g1-squid.axiom-team.fr/v1/graphql https://g1-squid.asycn.io/v1/graphql https://squid.g1.coinduf.eu/v1/graphql https://squid.g1.gyroi.de/v1/graphql https://squid.g1.brussels.ovh/v1/graphql https://g1-squid.pini.fr/v1/graphql https://g1.1000i100.fr/v1/graphql

# ─── DataPod (certifications avancées) ───────────────────────
DATAPOD_ENDPOINTS=https://datapod.gyroi.de/v1/graphql

# ─── Gateways IPFS ───────────────────────────────────────────
IPFS_GATEWAYS=https://ipfs.copylaradio.com https://ipfs.sagittarius.copylaradio.com https://ipfs.guenoel.fr

# ─── UPassport API ────────────────────────────────────────────
# Serveur de développement (UPlanet ORIGIN) :
UPASSPORT_URL=https://u.copylaradio.com
#
# Serveur de production (à déployer sur astroport.one) :
# UPASSPORT_URL=https://u.astroport.one
#
# 🔧 Pour que /api/feedback fonctionne côté landing server,
# configurer GITHUB_TOKEN (voir section Landing Server ci-dessous)
# OU configurer sur le serveur UPassport :
#       ~/.zen/UPassport/.env :
#           GITLAB_TOKEN=glpat-xxxx  (GitLab Duniter)
#       ou  GITHUB_TOKEN=ghp_xxxx    (GitHub)

# ─── NOSTR relay (optionnel) ─────────────────────────────────
# Convention : u.{domain} → wss://relay.{domain}
# Si vide, dérivé automatiquement depuis UPASSPORT_URL.
#
# Dev (copylaradio.com) :
NOSTR_RELAY=wss://relay.copylaradio.com
#
# Production (astroport.one, quand déployé) :
# NOSTR_RELAY=wss://relay.astroport.one

# ─── Clé GitLab (legacy — ancienne intégration directe) ──────
# Remplacée par /api/feedback → serveur UPassport/landing.
# GITLAB_TOKEN=

# ╔══════════════════════════════════════════════════════╗
# ║  LANDING SERVER (zelkova/landing/server.py)          ║
# ╚══════════════════════════════════════════════════════╝
#
# Token GitHub pour créer les issues feedback directement
# (sans passer par UPassport — déploiement léger)
#
# Comment obtenir un GitHub Token :
#   1. https://github.com/settings/tokens
#   2. "Fine-grained token" → Repository: papiche/zelkova
#   3. Permissions : Issues → Read & Write
#   4. Copier le token ici :
#
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Dépôt GitHub pour les issues
GITHUB_REPO=papiche/zelkova

# URL externe de la PWA (si build/web/ absent)
# ZELKOVA_APP_URL=https://zelkova.astroport.one

# Port du landing server (défaut 8080)
# PORT=8080

# ──────────────────────────────────────────────────────────────
# Démarrage rapide :
#   cd zelkova && cp dot.env.sample .env && nano .env
#   flutter pub get && flutter run
#
# Landing server :
#   cd zelkova/landing && pip install -r requirements.txt && python server.py
# ──────────────────────────────────────────────────────────────
